# === Job Hunt OS — Environment Variables ===

# --- AI ---
ANTHROPIC_API_KEY=

# --- Google (Drive integration for briefing export) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
NOTIFY_EMAIL_TO=

# --- Twilio (optional / legacy SMS notifications) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MY_PHONE_NUMBER=

# --- SQLite Replication (Litestream → S3/R2) ---
# s3://bucket-name/path  or  r2://bucket-name/path
LITESTREAM_REPLICA_URL=

# --- Cron Schedule (UTC) ---
# 7:00 AM PST = 2:00 PM UTC
CRON_SCHEDULE=0 14 * * *
