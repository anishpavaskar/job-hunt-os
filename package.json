    "dotenv": "^17.3.1",
    "google-auth": "^0.0.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "next": "16.2.1",
    "open": "^11.0.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "^4.1.16",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.13",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
