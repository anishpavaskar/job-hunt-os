{
  "name": "job-hunt-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "web:dev": "next dev --webpack",
    "web:build": "next build --webpack",
    "web:start": "next start",
    "cli:build": "tsc",
    "cli:dev": "ts-node src/cli.ts",
    "cli": "ts-node src/cli.ts",
    "scan": "ts-node src/cli.ts scan",
    "import": "ts-node src/cli.ts import",
    "notify": "ts-node src/cli.ts notify",
    "prospect-refresh": "ts-node src/cli.ts prospect-refresh",
    "review": "ts-node src/cli.ts review",
    "browse": "ts-node src/cli.ts browse",
    "stats": "ts-node src/cli.ts stats",
    "today": "ts-node src/cli.ts today --limit 10",
    "next": "ts-node src/cli.ts next --limit 10",
    "auto-draft": "ts-node src/cli.ts auto-draft",
    "draft": "ts-node src/cli.ts draft",
    "drafts": "ts-node src/cli.ts drafts",
    "apply": "ts-node src/cli.ts apply",
    "followups": "ts-node src/cli.ts followups",
    "profile": "ts-node src/cli.ts profile",
    "briefing": "ts-node src/cli.ts briefing",
    "baseline-bootstrap": "ts-node src/cli.ts baseline-bootstrap",
    "google-auth": "npx ts-node scripts/google-auth.ts",
    "migrate:supabase": "ts-node scripts/migrate-to-supabase.ts",
    "scan:careers": "ts-node src/cli.ts scan:careers",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --passWithNoTests --runInBand tests/pipeline.integration.test.ts",
    "typecheck": "tsc --noEmit"
